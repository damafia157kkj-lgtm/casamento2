# ===========================================================
# Variáveis de ambiente REAIS do projeto.
# Este arquivo NUNCA deve ser enviado ao GitHub (veja .gitignore).
# No Railway, essas mesmas variáveis são cadastradas na aba
# "Variables" do serviço — não é este arquivo que vai pro ar.
# ===========================================================

PORT=3000

# Banco de dados MySQL (no Railway, copie os valores da aba
# "Connect" / "Variables" do serviço MySQL que você criar lá)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=site_casamento

# Autenticação do painel administrativo
ADMIN_USER=arthur
ADMIN_PASSWORD_SALT=9325a294d40de11656d329cc25f3aec1
ADMIN_PASSWORD_HASH=f13e23030860f5eec742b082d122587a8887e7482a54cc5069d7728ab3e47677bef5a4acd652a508448400b59d00086efe8301b34bd63e6830052e45a39c2246

# Chave usada para assinar o token de login (troque por qualquer
# frase longa e aleatória antes de publicar)
